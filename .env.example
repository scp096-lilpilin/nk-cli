# nk-cli environment variables.
# Copy this file to `.env` and adjust values as needed.
# All keys are optional — every variable falls back to a safe default
# defined in `src/config/index.js`.

# ---- Target site ----------------------------------------------------------
# Root URL used to build per-slug detail page URLs.
NK_BASE_URL=https://nekopoi.care
# Homepage entry point used to find the "Hentai" menu link.
NK_HOME_URL=https://nekopoi.care/

# ---- Browser / fingerprint ------------------------------------------------
# Override the user-agent string presented to the site.
NK_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# Run Chromium headless (true) or visible (false). Set false to debug WAF.
NK_HEADLESS=true
# Default viewport size.
NK_VIEWPORT_WIDTH=1366
NK_VIEWPORT_HEIGHT=768
# Navigation / selector timeout in milliseconds.
NK_NAV_TIMEOUT_MS=60000
# Generous timeout for the SafeLine WAF challenge gate (homepage entry,
# Hentai-link wait, listing/detail DOM appearance). The WAF interstitial
# can take 30-90s to clear on a cold IP, so this is intentionally larger
# than NK_NAV_TIMEOUT_MS. Once the cookie is set subsequent waits resolve
# almost instantly, so a high ceiling has no per-page cost.
NK_WAF_TIMEOUT_MS=120000
# Comma-separated list of resource types blocked at the request layer.
# The scraper only needs HTML/CSS/JS to parse, so images/video/fonts are
# pure overhead. Allowed tokens: document, stylesheet, image, media, font,
# script, texttrack, xhr, fetch, eventsource, websocket, manifest, other.
# Use "none" to disable blocking entirely.
NK_BLOCK_RESOURCES=image,media,font
# Optional: run a real installed Chrome instead of the bundled Chromium.
# Bundled Chromium has well-known fingerprint quirks that some WAFs flag.
# Examples: /usr/bin/google-chrome, /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# NK_CHROME_EXECUTABLE_PATH=
# Optional Puppeteer browser channel hint (e.g. chrome, chrome-beta).
# NK_CHROME_CHANNEL=chrome

# ---- Anti-detection (rebrowser-patches) ----------------------------------
# rebrowser-puppeteer ships as the runtime puppeteer build (see package.json).
# These knobs are forwarded straight to rebrowser-patches; defaults are set
# automatically in src/browser/launcher.js but may be overridden here.
# Fix mode for the Runtime.Enable leak: addBinding (default) | alwaysIsolated | 0
# REBROWSER_PATCHES_RUNTIME_FIX_MODE=addBinding
# Replace the telltale `pptr:` script URL on injected sources.
# REBROWSER_PATCHES_SOURCE_URL=app.js
# Generic name for the Puppeteer utility world (default leaks "utility").
# REBROWSER_PATCHES_UTILITY_WORLD_NAME=1

# ---- Scrape pacing & limits ----------------------------------------------
# Hard cap on the number of /category/hentai listing pages.
NK_MAX_LIST_PAGES=9999
# Hard cap on detail pages per run; 0 means no cap.
NK_MAX_DETAIL_ITEMS=0
# Retries per page before skipping.
NK_RETRY_ATTEMPTS=3
# Base delay between retries (doubled on each retry).
NK_RETRY_BASE_DELAY_MS=2500
# Pause between successful requests, to be polite to the origin.
NK_POLITE_DELAY_MS=800

# ---- Output / filesystem layout ------------------------------------------
# All paths are resolved relative to the project root if not absolute.
# Override only when you want test runs / parallel jobs / CI to write
# elsewhere. Defaults: output/, logs/, .browser_data/.
# Listing JSON files land directly under NK_OUTPUT_DIR; detail output
# is split into per-prefix bucket files under
# `<NK_OUTPUT_DIR>/details/<categoryKey>/` (see README §Outputs).
# NK_OUTPUT_DIR=output
# NK_LOGS_DIR=logs
# NK_USER_DATA_DIR=.browser_data

# ---- Logging --------------------------------------------------------------
# One of: debug, info, warn, error
NK_LOG_LEVEL=info
# Force ANSI colour on/off / explicit chalk level. Accepted values:
#   auto (default), 0/false/off, 1/true/on, 2 (256-colour), 3 (truecolor)
# On Windows the logger forces level 1 when stdout is a TTY because
# chalk's auto-detection misfires on PowerShell + some terminals.
# Standard FORCE_COLOR=1 also works as a fallback.
# NK_LOG_COLOR=auto

# ---- CLI prompts ----------------------------------------------------------
# Auto-answer the post-listing "scrape detail pages?" prompt.
# Useful for non-interactive runs (CI, cron). yes|true|1 → continue;
# no|false|0 → stop after listing. Unset → ask interactively (or assume
# "no" when stdin isn't a TTY).
# NK_AUTO_DETAIL=no

# ---- Resume prompt (Yes/No/Cancel) ----------------------------------------
# Pre-answer the "An unfinished scraping progress was found. Continue
# from the last saved index?" prompt that appears when a previous run
# left an interrupted *.progress.meta.json file.
#   yes|true|1   → resume from lastCompletedIndex + 1 (preserves output)
#   no|false|0   → start fresh (chains into NK_RESUME_OVERWRITE below)
#   cancel       → exit immediately without mutating anything
# Unset → ask interactively (or assume "cancel" when stdin isn't a TTY).
# NK_RESUME=yes
# Pre-answer the destructive "This will overwrite the previously saved
# progress and output data. Are you sure?" follow-up prompt that fires
# whenever a fresh run would clobber an existing progress/output pair.
#   yes|true|1   → archive the previous files and start fresh
#   no|false|0   → keep the previous files and exit safely
#   cancel       → keep the previous files and exit safely
# Unset → ask interactively (or assume "cancel" when stdin isn't a TTY).
# NK_RESUME_OVERWRITE=yes
